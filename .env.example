# airbotix-app env (V0)

# API endpoint (platform-backend)
VITE_API_BASE_URL=https://api.airbotix.ai

# WebSocket endpoint (same origin in prod)
VITE_WS_URL=wss://api.airbotix.ai/ws

# Sentry (optional)
# VITE_SENTRY_DSN=

# Music Stage GM soundfont base (optional). Defaults to smplr's official
# source; switch to our S3+CloudFront host before launch (music-stage-prd OQ-3).
# VITE_SOUNDFONT_BASE_URL=https://cdn.airbotix.ai/soundfonts
