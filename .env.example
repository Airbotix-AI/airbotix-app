# airbotix-app env (V0)

# API endpoint (platform-backend)
VITE_API_BASE_URL=https://api.airbotix.ai

# WebSocket endpoint (same origin in prod)
VITE_WS_URL=wss://api.airbotix.ai/ws

# Sentry (optional)
# VITE_SENTRY_DSN=

# Music Stage sample base — REQUIRED in production for sampled timbres
# (music-stage-prd OQ-3 launch gate). Must be our own origin (S3+CloudFront),
# hosting the gleitz soundfont layout at the root and the smpldsnds
# drum-machine layout under /drum-machines. If unset, production builds
# disable the whole smplr path and play the Tone.js fallback voices (AC-11);
# only DEV builds fall back to the external default sources.
# VITE_SOUNDFONT_BASE_URL=https://cdn.airbotix.ai/soundfonts
